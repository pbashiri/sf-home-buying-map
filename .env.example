# =============================================================================
# Theami environment.
#
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# This file (`.env.example`) IS committed — keep it placeholder-only.
#
# The app gracefully degrades when keys are missing. Tier 0 = nothing required.
# =============================================================================


# -----------------------------------------------------------------------------
# Tier 0: zero-config local dev
# -----------------------------------------------------------------------------
# `npm run dev` works with nothing set. The app falls back to free alternatives
# for every external service. See DECISIONS.md D1.


# -----------------------------------------------------------------------------
# Tier 1: production launch (theami.ai)
# -----------------------------------------------------------------------------

# Claude (Anthropic). Without this, summaries fall back to a deterministic stub.
# https://console.anthropic.com/  ~$0.005/address with prompt caching.
ANTHROPIC_API_KEY=

# Google Places + Geocoding. Without this, autocomplete falls back to a local
# SF gazetteer + Nominatim. Restrict by HTTP referrer.
# https://console.cloud.google.com/  ~$25/mo at modest traffic.
GOOGLE_MAPS_API_KEY=

# MapTiler vector tiles. Without this, falls back to OpenFreeMap "liberty" (CC-BY).
# https://www.maptiler.com/  NEXT_PUBLIC_ — restrict by domain.
NEXT_PUBLIC_MAPTILER_KEY=

# DataSF Socrata token. Free; exempts you from public ingestion throttling.
# https://data.sfgov.org/profile/edit/developer_settings
DATASF_APP_TOKEN=

# Required to enable /api/ingest/* in production. Generate: `openssl rand -hex 32`
VERCEL_CRON_SECRET=


# -----------------------------------------------------------------------------
# Tier 2: production cache + observability (recommended, not required)
# -----------------------------------------------------------------------------

# Upstash Redis. Without this, an in-process LRU is used.
# Free tier: 10k commands/day. https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — error tracking. https://sentry.io/  Free tier: 5k errors/mo.
SENTRY_DSN=

# PostHog — product analytics + session replay.
# https://posthog.com/  Free tier: 1M events/mo. NEXT_PUBLIC_ — sent from browser.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# -----------------------------------------------------------------------------
# Tier 3: Supabase auth + saved homes (required for sign-in / saved homes)
# -----------------------------------------------------------------------------
# Without these, the sign-in box shows "Connect Supabase env vars to enable login."
# The rest of the app (search, map, concerns, summary) keeps working.
#
# After filling these in, also run db/migrations/0001_saved_homes.sql in the
# Supabase SQL Editor (see "After filling these in" section in the chat).
#
# From Supabase → Project Settings → API (hosted projects):
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the new publishable key (`sb_publishable_…`). If unset, the app falls
# back to the legacy anon JWT below.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy public key (JWT-shaped `anon`). Optional if PUBLISHABLE_KEY is set.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: legacy `service_role` JWT or new secret key (`sb_secret_…`).
# Used by /api/saved-homes/chat and /share/[token] (RLS-safe reads of shared rows).
# You can set either this or SUPABASE_SECRET_KEY (same value if you only create one secret).
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# DATABASE_URL is only needed for running Drizzle migrations from the CLI
# (`npm run db:migrate`). The app itself uses the Supabase JS client and
# doesn't need DATABASE_URL at runtime. Use the transaction pooler on port
# 6543 with `?pgbouncer=true` for serverless-safe connections.
DATABASE_URL=
